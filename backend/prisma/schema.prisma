generator client {
  provider = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas  = ["public"]
}

model Student {
  id          String       @id
  email       String       @unique
  name        String?
  studentId   String?
  profileData Json?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  role        String       @default("student")
  enrollments Enrollment[]
  reviews     Review[]
  @@schema("public")
}

model Course {
  id          Int          @id @default(autoincrement())
  courseCode  String       @unique
  name        String
  credits     Int
  enrollments Enrollment[]
  reviews     Review[]
  @@schema("public")
}

model Enrollment {
  id        Int     @id @default(autoincrement())
  grade     Float?
  studentId String
  courseId  Int
  course    Course  @relation(fields: [courseId], references: [id])
  student   Student @relation(fields: [studentId], references: [id])
  @@schema("public")
}

model Review {
  id        Int      @id @default(autoincrement())
  comment   String
  rating    Int
  sentiment String?
  likes     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  studentId String
  courseId  Int
  course    Course   @relation(fields: [courseId], references: [id])
  author    Student  @relation(fields: [studentId], references: [id])
  @@schema("public")
}
